<% content_for :title, "Criar conta | Organiza Feature" %>

<main class="flex min-h-screen flex-col justify-center px-6 py-12 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-sm">
    <h1 class="text-center text-2xl font-bold tracking-tight text-gray-900">Criar nova conta</h1>

    <%= form_with model: resource, as: resource_name, url: registration_path(resource_name), class: "mt-10 space-y-6" do |form| %>
      <% if resource.errors.any? %>
        <div class="rounded-md bg-red-50 p-4 text-sm text-red-700">
          <ul class="list-disc space-y-1 pl-5">
            <% resource.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= form.label :email, class: "block text-sm font-medium text-gray-900" %>
        <%= form.email_field :email, autofocus: true, autocomplete: "email", required: true, class: "mt-2 block w-full rounded-md border-0 px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-indigo-600" %>
      </div>

      <div>
        <%= form.label :password, "Senha", class: "block text-sm font-medium text-gray-900" %>
        <%= form.password_field :password, autocomplete: "new-password", required: true, class: "mt-2 block w-full rounded-md border-0 px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-indigo-600" %>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirmar senha", class: "block text-sm font-medium text-gray-900" %>
        <%= form.password_field :password_confirmation, autocomplete: "new-password", required: true, class: "mt-2 block w-full rounded-md border-0 px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-indigo-600" %>
      </div>

      <%= form.submit "Cadastrar", class: "flex w-full cursor-pointer justify-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500" %>
    <% end %>

    <p class="mt-10 text-center text-sm text-gray-500">
      Já tem uma conta?
      <%= link_to "Faça login", new_user_session_path, class: "font-semibold text-indigo-600 hover:text-indigo-500" %>
    </p>
  </div>
</main>

<% content_for :title, "Entrar | Organiza Feature" %>

<main class="flex min-h-screen flex-col justify-center px-6 py-12 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-sm">
    <h1 class="text-center text-2xl font-bold tracking-tight text-gray-900">Entrar na sua conta</h1>

    <%= form_with model: resource, as: resource_name, url: session_path(resource_name), class: "mt-10 space-y-6" do |form| %>
      <div>
        <%= form.label :email, class: "block text-sm font-medium text-gray-900" %>
        <%= form.email_field :email, autofocus: true, autocomplete: "email", required: true, class: "mt-2 block w-full rounded-md border-0 px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-indigo-600" %>
      </div>

      <div>
        <%= form.label :password, "Senha", class: "block text-sm font-medium text-gray-900" %>
        <%= form.password_field :password, autocomplete: "current-password", required: true, class: "mt-2 block w-full rounded-md border-0 px-3 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-indigo-600" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2">
          <%= form.check_box :remember_me, class: "rounded border-gray-300 text-indigo-600" %>
          <%= form.label :remember_me, "Lembrar de mim", class: "text-sm text-gray-700" %>
        </div>
      <% end %>

      <%= form.submit "Entrar", class: "flex w-full cursor-pointer justify-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500" %>
    <% end %>

    <p class="mt-10 text-center text-sm text-gray-500">
      Não tem uma conta?
      <%= link_to "Cadastre-se", new_user_registration_path, class: "font-semibold text-indigo-600 hover:text-indigo-500" %>
    </p>
  </div>
</main>

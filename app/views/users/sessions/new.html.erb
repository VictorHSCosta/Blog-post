<% content_for :title, "Entrar | Organiza Feature" %>

<main class="relative flex min-h-screen items-center justify-center overflow-hidden bg-slate-950 px-6 py-12">
  <div aria-hidden="true" class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(99,102,241,0.18),_transparent_38%),radial-gradient(circle_at_bottom_right,_rgba(14,165,233,0.12),_transparent_38%)]"></div>

  <section class="relative w-full max-w-md rounded-3xl border border-white/10 bg-white p-8 shadow-2xl shadow-black/30 sm:p-10">
    <header class="mb-8 text-center">
      <div class="mx-auto flex size-12 items-center justify-center rounded-2xl bg-indigo-600 text-lg font-bold text-white shadow-lg shadow-indigo-600/25">
        OF
      </div>
      <p class="mt-5 text-xs font-semibold uppercase tracking-[0.22em] text-indigo-600">Organiza Feature</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900">Bem-vindo de volta</h1>
      <p class="mt-2 text-sm leading-6 text-slate-500">Entre com seus dados para acessar o painel.</p>
    </header>

    <%= form_with model: resource, as: resource_name, url: session_path(resource_name), class: "space-y-5" do |form| %>
      <div>
        <%= form.label :email, "E-mail", class: "block text-sm font-semibold text-slate-700" %>
        <%= form.email_field :email,
          autofocus: true,
          autocomplete: "email",
          required: true,
          placeholder: "voce@exemplo.com",
          class: "mt-2 block w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-indigo-500 focus:bg-white focus:ring-4 focus:ring-indigo-500/10" %>
      </div>

      <div>
        <%= form.label :password, "Senha", class: "block text-sm font-semibold text-slate-700" %>
        <%= form.password_field :password,
          autocomplete: "current-password",
          required: true,
          placeholder: "Digite sua senha",
          class: "mt-2 block w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-indigo-500 focus:bg-white focus:ring-4 focus:ring-indigo-500/10" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2.5">
          <%= form.check_box :remember_me, class: "size-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" %>
          <%= form.label :remember_me, "Manter minha sessão ativa", class: "select-none text-sm text-slate-600" %>
        </div>
      <% end %>

      <%= form.submit "Acessar o painel", class: "flex w-full cursor-pointer justify-center rounded-xl bg-indigo-600 px-4 py-3 text-sm font-bold text-white shadow-lg shadow-indigo-600/20 transition hover:bg-indigo-500 focus:outline-none focus:ring-4 focus:ring-indigo-500/25 active:translate-y-px" %>
    <% end %>

    <p class="mt-8 text-center text-xs text-slate-400">Área de acesso restrito</p>
  </section>
</main>
